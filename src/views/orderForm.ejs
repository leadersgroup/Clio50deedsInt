<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>New Order — 50deeds</title>
  <style>
    :root{--ink:#1a2b4a;--muted:#6b7a93;--line:#e2e8f2;--chip:#eaf0fb;--chipink:#2b4a86;--blue:#2563eb;--blue-dim:#a9bff2;--soft:#f7f9fc;}
    *{box-sizing:border-box;}
    body{font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:var(--ink);background:#fafbfd;margin:0;}
    .wrap{max-width:760px;margin:0 auto;padding:24px 20px 80px;}
    .top{display:flex;align-items:center;gap:12px;margin:8px 0 22px;}
    .back{display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border:1px solid var(--line);border-radius:10px;background:#fff;color:var(--ink);text-decoration:none;font-size:18px;}
    h1{font-size:24px;margin:0;font-weight:800;}
    .card{background:#fff;border:1px solid var(--line);border-radius:14px;padding:24px;}
    .card-title{font-size:16px;font-weight:800;margin:0 0 18px;}
    label{display:block;font-size:14px;font-weight:700;margin:18px 0 8px;}
    label:first-of-type{margin-top:0;}
    input[type=text],input[type=email],textarea{width:100%;padding:12px 14px;border:1px solid var(--line);border-radius:10px;font-size:14px;font-family:inherit;background:#fff;color:var(--ink);}
    input::placeholder,textarea::placeholder{color:#9aa7bd;}
    gmp-place-autocomplete{width:100%;display:block;}
    .pairrow{display:flex;gap:14px;align-items:flex-end;}
    .pairrow .grow{flex:1;min-width:0;}
    .pairrow .ssnbox{flex:0 0 150px;}
    textarea{min-height:84px;resize:vertical;}
    .transfer{background:var(--soft);border:1px solid var(--line);border-radius:10px;padding:14px 16px;}
    .transfer .line{display:flex;align-items:center;gap:8px;flex-wrap:wrap;font-size:14px;color:var(--muted);}
    .chip{display:inline-block;background:var(--chip);color:var(--chipink);font-weight:700;font-size:13px;padding:3px 12px;border-radius:999px;}
    .arrow{color:var(--muted);font-weight:700;}
    .transfer .desc{color:var(--muted);font-style:italic;font-size:13px;margin-top:8px;}
    .linkbtn{margin-top:10px;background:none;border:none;color:var(--blue);font-weight:700;font-size:13px;cursor:pointer;padding:0;}
    .price-head{display:flex;align-items:center;gap:8px;font-weight:800;font-size:18px;margin:24px 0 12px;}
    .price-head .price-ico{color:var(--blue);}
    .price-card{border:1px solid var(--line);border-radius:12px;padding:16px 20px;background:#fcfdff;}
    .price-empty{color:var(--muted);font-size:14px;}
    .price-row{display:flex;justify-content:space-between;align-items:center;font-size:15px;color:#3a4a63;padding:7px 0;}
    .price-total{display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--line);margin-top:8px;padding-top:14px;font-weight:800;font-size:16px;}
    .price-total .amt{font-size:24px;font-weight:800;}
    .docs-head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:22px;}
    .docs-head .lab{font-size:13px;font-weight:700;}
    .docs-head .lab .muted{font-weight:500;}
    .upload-btn{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line);background:#fff;border-radius:10px;padding:9px 14px;font-weight:700;font-size:13px;cursor:pointer;white-space:nowrap;}
    .uploads{margin-top:12px;display:flex;flex-direction:column;gap:8px;}
    .uploads .row{display:flex;justify-content:space-between;align-items:center;font-size:13px;background:var(--soft);border:1px solid var(--line);border-radius:8px;padding:9px 12px;}
    .muted{color:var(--muted);}
    .sub-note{font-size:12px;color:var(--muted);margin-top:8px;}
    .submit-row{display:flex;justify-content:flex-end;margin-top:22px;}
    .btn-submit{background:var(--blue);color:#fff;border:none;border-radius:12px;padding:13px 24px;font-weight:800;font-size:15px;cursor:pointer;}
    .btn-submit:disabled{background:var(--blue-dim);cursor:not-allowed;}

    /* Transfer-parties modal */
    .modal-backdrop{position:fixed;inset:0;background:rgba(15,23,42,.45);display:none;align-items:center;justify-content:center;padding:20px;z-index:50;}
    .modal-backdrop.open{display:flex;}
    .modal{background:#fff;border-radius:14px;max-width:430px;width:100%;padding:24px 24px 22px;position:relative;box-shadow:0 20px 60px rgba(15,23,42,.25);}
    .modal h2{font-size:18px;font-weight:800;margin:0 0 18px;}
    .modal-x{position:absolute;top:14px;right:16px;background:none;border:none;font-size:20px;color:var(--muted);cursor:pointer;line-height:1;}
    .q{font-size:14px;font-weight:700;margin:14px 0 10px;}
    .opts{display:flex;gap:10px;}
    .opt{flex:1;border:1px solid var(--line);background:#fff;color:var(--ink);border-radius:10px;padding:12px 8px;font-weight:700;font-size:14px;cursor:pointer;}
    .opt.sel{border-color:var(--blue);background:#eef3fe;color:var(--chipink);box-shadow:0 0 0 1px var(--blue) inset;}
    .btn-continue{width:100%;margin-top:22px;background:var(--blue);color:#fff;border:none;border-radius:12px;padding:13px;font-weight:800;font-size:15px;cursor:pointer;}
    .btn-continue:disabled{background:var(--blue-dim);cursor:not-allowed;}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <a class="back" href="<%= matterUrl || '#' %>" aria-label="Back to Clio matter">&larr;</a>
      <h1>New Order</h1>
    </div>

    <form id="orderForm" method="POST" action="/order/<%= draftId %>/submit">
      <div class="card">
        <div class="card-title">Order Details</div>

        <label>Type of Transfers</label>
        <div class="transfer">
          <div class="line">
            <span>From:</span> <span class="chip" id="fromChip">&mdash;</span>
            <span class="arrow">&rarr;</span>
            <span>To:</span> <span class="chip" id="toChip">&mdash;</span>
          </div>
          <div class="desc" id="transferDesc">Choose who is transferring and who is receiving the property.</div>
          <button type="button" class="linkbtn" id="editTransfer">Choose transfer parties</button>
        </div>

        <label>Property Address</label>
        <div id="addrMount">
          <input type="text" name="propertyAddress" id="propertyAddress" value="<%= d.propertyAddress.value %>" placeholder="Enter the property address..." autocomplete="off" required />
        </div>
        <input type="hidden" name="city" id="city" value="<%= d.city ? d.city.value : '' %>" />

        <div class="pairrow">
          <div class="grow">
            <label>Homeowner Name</label>
            <input type="text" name="grantorName" id="grantorName" value="<%= d.grantorName.value %>" placeholder="As shown on last recorded deed" required />
          </div>
          <div class="ssnbox" id="ssnGrantorRow" style="display:none">
            <label>SSN <span class="muted">(NY)</span></label>
            <input type="text" name="grantorSsn" id="grantorSsn" value="" placeholder="XXX-XX-XXXX" autocomplete="off" inputmode="numeric" />
          </div>
        </div>

        <div class="pairrow">
          <div class="grow">
            <label>New Owner Name <span class="muted" id="toLabel"></span></label>
            <input type="text" name="granteeName" id="granteeName" value="<%= d.granteeName.value %>" placeholder="Name of the trust, individual, or company receiving title" required />
          </div>
          <div class="ssnbox" id="ssnGranteeRow" style="display:none">
            <label>SSN <span class="muted">(NY)</span></label>
            <input type="text" name="granteeSsn" id="granteeSsn" value="" placeholder="XXX-XX-XXXX" autocomplete="off" inputmode="numeric" />
          </div>
        </div>

        <label>Contact email <span class="muted">(for order updates)</span></label>
        <input type="email" name="contactEmail" id="contactEmail" value="<%= d.contactEmail.value %>" placeholder="attorney@firm.com" required />

        <div class="price-head"><span class="price-ico">&#127991;</span> Price Estimate</div>
        <div class="price-card">
          <div class="price-empty" id="priceEmpty">Enter a valid property address to calculate the price.</div>
          <div id="priceLines" style="display:none"></div>
        </div>

        <label>Additional Instructions (Optional)</label>
        <textarea name="additionalInstructions" placeholder="Enter any special requests or notes here..."><%= d.additionalInstructions ? d.additionalInstructions.value : '' %></textarea>

        <div class="docs-head">
          <div class="lab">Supporting Documents <span class="muted">(Upload Homeowner ID, last recorded deed and/or Certificate of Trust)</span></div>
          <label class="upload-btn">&uarr; Upload Files
            <input type="file" id="fileInput" multiple accept=".pdf,.png,.jpg,.jpeg,.tif,.tiff,.doc,.docx" style="display:none" />
          </label>
        </div>
        <div class="uploads" id="uploads"></div>
        <div class="sub-note" id="uploadStatus"></div>
      </div>

      <!-- Deed type is fixed; transfer parties are captured for the order notes. -->
      <input type="hidden" name="deedType" id="deedType" value="<%= initialDeedType %>" />
      <input type="hidden" name="transferFrom" id="transferFrom" value="<%= d.transferFrom ? d.transferFrom.value : '' %>" />
      <input type="hidden" name="transferTo" id="transferTo" value="<%= d.transferTo ? d.transferTo.value : '' %>" />
      <!-- Required by the Enterprise order but derived/pre-filled, not shown as primary fields -->
      <input type="hidden" name="county" id="county" value="<%= d.county.value %>" />
      <input type="hidden" name="state" id="state" value="<%= d.state.value %>" />
      <input type="hidden" name="apn" id="apn" value="<%= d.apn.value %>" />
      <input type="hidden" name="legalDescription" id="legalDescription" value="<%= d.legalDescription.value %>" />
      <input type="hidden" name="priorDeedReference" id="priorDeedReference" value="<%= d.priorDeedReference.value %>" />
      <input type="hidden" name="matterReference" value="<%= d.matterReference.value %>" />

      <div class="submit-row">
        <button type="submit" class="btn-submit" id="submitBtn" disabled>Submit Order &#9658;</button>
      </div>
      <p class="sub-note" style="text-align:right">Secure payment via Stripe · recorded against Clio matter <%= d.matterReference.value || '' %>.</p>
    </form>
  </div>

  <!-- Transfer-parties modal -->
  <div class="modal-backdrop" id="modal">
    <div class="modal">
      <button type="button" class="modal-x" id="modalClose" aria-label="Close">&times;</button>
      <h2>Tell us about the transfer parties</h2>
      <div class="q">Who is transferring the property?</div>
      <div class="opts" data-group="from">
        <% transferParties.forEach(function(p){ %><button type="button" class="opt" data-val="<%= p %>"><%= p %></button><% }) %>
      </div>
      <div class="q">Who is receiving the property?</div>
      <div class="opts" data-group="to">
        <% transferParties.forEach(function(p){ %><button type="button" class="opt" data-val="<%= p %>"><%= p %></button><% }) %>
      </div>
      <button type="button" class="btn-continue" id="modalContinue" disabled>Continue</button>
    </div>
  </div>

  <script>
    const $ = (id) => document.getElementById(id);
    let selFrom = $('transferFrom').value || '';
    let selTo = $('transferTo').value || '';
    let uploading = false;
    const ALLOWED_EXT = ['pdf', 'png', 'jpg', 'jpeg', 'tif', 'tiff', 'doc', 'docx'];

    function applyTransfer() {
      $('fromChip').textContent = selFrom || '—';
      $('toChip').textContent = selTo || '—';
      $('transferFrom').value = selFrom;
      $('transferTo').value = selTo;
      if (selFrom && selTo) {
        $('deedType').value = selFrom + ' to ' + selTo.toLowerCase();
        $('transferDesc').textContent = 'Transfer from ' + selFrom + ' to ' + selTo + '.';
        $('toLabel').textContent = '(the ' + selTo + ')';
      } else {
        $('deedType').value = '';
        $('transferDesc').textContent = 'Choose who is transferring and who is receiving the property.';
        $('toLabel').textContent = '';
      }
    }

    function showPriceMsg(msg) {
      $('priceLines').style.display = 'none';
      $('priceEmpty').style.display = 'block';
      $('priceEmpty').textContent = msg;
    }
    function renderPrice(data) {
      if (!data || !data.display) { showPriceMsg('Enter a valid property address to calculate the price.'); return; }
      const money = (n) => '$' + Number(n || 0).toFixed(2);
      const esc = (s) => String(s).replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
      const b = data.breakdown;
      const rows = [];
      let total;
      if (b && typeof b.total === 'number') {
        rows.push(['Service Fee', money(b.service_fee)]);
        rows.push(['Estimated Recording Fee', money(Number(b.recording_fee || 0) + Number(b.trust_recording_fee || 0))]);
        if (Number(b.fincen_fee) > 0) rows.push(['FinCEN Fee', money(b.fincen_fee)]);
        if (Number(b.premium_discount) > 0) rows.push(['Discount', '-' + money(b.premium_discount)]);
        total = money(b.total);
      } else {
        rows.push(['Estimated Total', data.display]);
        total = data.display;
      }
      let html = rows.map((r) => '<div class="price-row"><span>' + esc(r[0]) + '</span><span>' + esc(r[1]) + '</span></div>').join('');
      html += '<div class="price-total"><span>Total Price</span><span class="amt">' + esc(total) + '</span></div>';
      $('priceLines').innerHTML = html;
      $('priceLines').style.display = 'block';
      $('priceEmpty').style.display = 'none';
    }

    function isNY() { return $('state').value.trim().toUpperCase() === 'NY'; }
    function toggleSsn() {
      const show = isNY() ? '' : 'none';
      $('ssnGrantorRow').style.display = show;
      $('ssnGranteeRow').style.display = show;
    }
    function validate() {
      const ny = isNY();
      const ok = !uploading && selFrom && selTo && $('propertyAddress').value.trim()
        && $('grantorName').value.trim() && $('granteeName').value.trim()
        && $('contactEmail').value.trim()
        && (!ny || ($('grantorSsn').value.trim() && $('granteeSsn').value.trim()));
      $('submitBtn').disabled = !ok;
    }

    // ── Modal ──────────────────────────────────────────────────────────────
    function openModal() {
      document.querySelectorAll('.opts[data-group="from"] .opt').forEach((b) => b.classList.toggle('sel', b.dataset.val === selFrom));
      document.querySelectorAll('.opts[data-group="to"] .opt').forEach((b) => b.classList.toggle('sel', b.dataset.val === selTo));
      $('modalContinue').disabled = !(selFrom && selTo);
      $('modal').classList.add('open');
    }
    function closeModal() { $('modal').classList.remove('open'); }

    document.querySelectorAll('.opts').forEach((group) => {
      group.addEventListener('click', (e) => {
        const btn = e.target.closest('.opt');
        if (!btn) return;
        group.querySelectorAll('.opt').forEach((b) => b.classList.remove('sel'));
        btn.classList.add('sel');
        const val = btn.dataset.val;
        if (group.dataset.group === 'from') selFrom = val; else selTo = val;
        $('modalContinue').disabled = !(selFrom && selTo);
      });
    });
    $('modalContinue').addEventListener('click', () => { closeModal(); applyTransfer(); validate(); updatePrice(); });
    $('modalClose').addEventListener('click', closeModal);
    $('editTransfer').addEventListener('click', openModal);

    // ── Address → county lookup → price ──────────────────────────────────────
    async function lookupAndPrice() {
      const address = $('propertyAddress').value.trim();
      if (!address) { showPriceMsg('Enter a valid property address to calculate the price.'); return; }
      showPriceMsg('Calculating price…');
      try {
        const r = await fetch('/order/<%= draftId %>/county-lookup', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ address, state: $('state').value, county: $('county').value }),
        });
        const d = await r.json();
        if (d.found) {
          $('apn').value = d.apn || '';
          $('legalDescription').value = d.legalDescription || '';
          $('priorDeedReference').value = d.priorDeedReference || '';
          if (d.county && !$('county').value.trim()) $('county').value = d.county;
          if (d.state && !$('state').value.trim()) $('state').value = d.state;
        }
      } catch (e) {}
      await updatePrice();
    }

    async function updatePrice() {
      toggleSsn();
      validate();
      const state = $('state').value.trim().toUpperCase();
      if (state.length !== 2) { renderPrice(null); return; }
      try {
        const p = new URLSearchParams({ state, county: $('county').value.trim(), deedType: $('deedType').value });
        const r = await fetch('/order/price?' + p.toString());
        const data = await r.json();
        renderPrice(data);
      } catch (e) {
        showPriceMsg('Could not calculate price automatically — we’ll confirm before payment.');
      }
    }

    // ── File upload (base64 → JSON) ──────────────────────────────────────────
    $('fileInput').addEventListener('change', async (e) => {
      const files = Array.from(e.target.files || []);
      if (!files.length) return;
      // Block submit while uploads are in flight so an order can't be placed before
      // its supporting documents finish attaching.
      uploading = true;
      validate();
      for (const f of files) {
        if (f.size > 14 * 1024 * 1024) {
          $('uploadStatus').textContent = f.name + ' is too large (max 14 MB).';
          continue;
        }
        if (!ALLOWED_EXT.includes((f.name.split('.').pop() || '').toLowerCase())) {
          $('uploadStatus').textContent = f.name + ': unsupported type. Allowed: PDF, PNG, JPG, TIFF, DOC, DOCX.';
          continue;
        }
        $('uploadStatus').textContent = 'Uploading ' + f.name + '…';
        try {
          const b64 = await new Promise((res, rej) => {
            const fr = new FileReader();
            fr.onload = () => res(String(fr.result).split(',')[1]);
            fr.onerror = rej;
            fr.readAsDataURL(f);
          });
          const r = await fetch('/order/<%= draftId %>/upload', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ file_name: f.name, mime: f.type, data_base64: b64 }),
          });
          const d = await r.json();
          if (r.ok) {
            const row = document.createElement('div');
            row.className = 'row';
            row.innerHTML = '<span>📄 ' + d.file_name + '</span><span class="muted">'
              + Math.max(1, Math.round(d.file_size / 1024)) + ' KB</span>';
            $('uploads').appendChild(row);
            $('uploadStatus').textContent = '';
          } else {
            $('uploadStatus').textContent = d.error || 'Upload failed.';
          }
        } catch (err) {
          $('uploadStatus').textContent = 'Upload failed for ' + f.name + '.';
        }
      }
      uploading = false;
      validate();
      e.target.value = '';
    });

    ['propertyAddress', 'grantorName', 'granteeName', 'contactEmail', 'grantorSsn', 'granteeSsn'].forEach((id) => $(id).addEventListener('input', validate));
    $('propertyAddress').addEventListener('blur', lookupAndPrice);

    // Called by the Google Places autocomplete after it sets state/county/city.
    window.onPlaceResolved = function () { lookupAndPrice(); validate(); };

    applyTransfer();
    toggleSsn();
    validate();
    if ($('propertyAddress').value.trim()) lookupAndPrice();
    // First-run: prompt for transfer parties like the native flow.
    if (!(selFrom && selTo)) openModal();
  </script>

  <% if (googleMapsApiKey) { %>
  <script>
    // Google Places Autocomplete on the property address. On select, derive
    // state / county / city, then run the county lookup + Enterprise pricing.
    window.__initPlaces = async function () {
      try {
        const { PlaceAutocompleteElement } = await google.maps.importLibrary('places');
        const mount = document.getElementById('addrMount');
        const plain = document.getElementById('propertyAddress');
        const pac = new PlaceAutocompleteElement();
        pac.id = 'placeAC';
        plain.type = 'hidden';            // keep as the form value carrier
        mount.appendChild(pac);
        pac.addEventListener('gmp-select', async (event) => {
          try {
            const place = event.placePrediction.toPlace();
            await place.fetchFields({ fields: ['formattedAddress', 'addressComponents'] });
            const comps = place.addressComponents || [];
            const pick = (type, short) => {
              const c = comps.find((x) => (x.types || []).includes(type));
              return c ? (short ? c.shortText : c.longText) : '';
            };
            const state = pick('administrative_area_level_1', true);
            const county = (pick('administrative_area_level_2', false) || '').replace(/\s+County$/i, '');
            const city = pick('locality', false) || pick('postal_town', false) || pick('sublocality_level_1', false);
            document.getElementById('propertyAddress').value = place.formattedAddress || '';
            document.getElementById('state').value = state;
            document.getElementById('county').value = county;
            document.getElementById('city').value = city;
            if (window.onPlaceResolved) window.onPlaceResolved();
          } catch (e) { /* leave fields for manual entry */ }
        });
      } catch (e) { /* Maps failed to load -> manual address input remains */ }
    };
  </script>
  <script async src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&libraries=places&loading=async&callback=__initPlaces"></script>
  <% } %>
</body>
</html>
