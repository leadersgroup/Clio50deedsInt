# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
# Public HTTPS base URL of THIS app (Railway gives you one). No trailing slash.
APP_BASE_URL=https://your-app.up.railway.app
PORT=3000
NODE_ENV=production

# 32-byte key (base64) used to encrypt OAuth tokens at rest (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Secret used to sign OAuth `state` / draft cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Clio Manage API v4 (US server)
# ─────────────────────────────────────────────────────────────────────────────
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
# Must exactly match the redirect URI registered in the Clio Developer Portal.
CLIO_REDIRECT_URI=https://your-app.up.railway.app/clio/callback
# US server. Override for other regions (out of scope for v1).
CLIO_API_BASE=https://app.clio.com/api/v4
CLIO_AUTH_BASE=https://app.clio.com

# ─────────────────────────────────────────────────────────────────────────────
# Database (Postgres). Railway injects DATABASE_URL automatically.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Set to "true" if your Postgres requires SSL but uses a self-signed cert (Railway internal does not).
PGSSL=false

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (existing 50deeds account)
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen` / dashboard webhook endpoint. Optional but recommended.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────────────────────
# 50deeds existing systems (adapters). Leave blank to run in MOCK mode for local dev.
# ─────────────────────────────────────────────────────────────────────────────
# Existing 50deeds order-create endpoint (Base44 + Node middleware).
ORDER_SYSTEM_URL=
ORDER_SYSTEM_API_KEY=
# Existing 50deeds county property-record lookup service.
COUNTY_LOOKUP_URL=
COUNTY_LOOKUP_API_KEY=
