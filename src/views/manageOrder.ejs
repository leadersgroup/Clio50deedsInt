<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Your 50deeds order — 50deeds</title>
  <style>
    :root{--ink:#1a2b4a;--muted:#6b7a93;--line:#e2e8f2;--blue:#2563eb;--soft:#f7f9fc;--green:#1a7f4b;--amber:#b26a00;}
    *{box-sizing:border-box;}
    body{font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:var(--ink);background:#fafbfd;margin:0;}
    .wrap{max-width:680px;margin:0 auto;padding:24px 20px 80px;}
    .top{display:flex;align-items:center;gap:12px;margin:8px 0 6px;}
    .back{display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;border:1px solid var(--line);border-radius:10px;background:#fff;color:var(--ink);text-decoration:none;font-size:18px;}
    h1{font-size:22px;margin:0;font-weight:800;flex:1;}
    .refresh{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--line);background:#fff;border-radius:10px;padding:8px 14px;font-weight:700;font-size:13px;cursor:pointer;color:var(--ink);}
    .refresh:disabled{color:var(--muted);cursor:default;}
    .sub{color:var(--muted);font-size:14px;margin:0 0 20px;}
    .card{background:#fff;border:1px solid var(--line);border-radius:14px;padding:20px;margin-bottom:16px;}
    .row1{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:10px;}
    .ordno{font-weight:800;font-size:15px;}
    code{background:#f1f4f9;padding:2px 6px;border-radius:4px;}
    .badge{font-size:12px;font-weight:700;padding:4px 12px;border-radius:999px;background:#eaf0fb;color:#2b4a86;white-space:nowrap;}
    .badge.removed{background:#fde8e8;color:#b42318;}
    .meta{font-size:14px;color:#3a4a63;padding:3px 0;}
    .docs-head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:16px;border-top:1px solid var(--line);padding-top:14px;}
    .docs-head .lab{font-size:13px;font-weight:700;}
    .upload-btn{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line);background:#fff;border-radius:10px;padding:9px 14px;font-weight:700;font-size:13px;cursor:pointer;}
    .uploads{margin-top:10px;display:flex;flex-direction:column;gap:6px;}
    .frow{display:flex;justify-content:space-between;align-items:center;gap:10px;font-size:13px;background:var(--soft);border:1px solid var(--line);border-radius:8px;padding:8px 12px;}
    .frow a{color:var(--blue);text-decoration:none;font-weight:600;}
    .frow a:hover{text-decoration:underline;}
    .muted{color:var(--muted);}
    .sub-note{font-size:12px;color:var(--muted);margin-top:8px;min-height:16px;}
    .empty{color:var(--muted);font-size:14px;}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <a class="back" href="<%= matterUrl || '#' %>" aria-label="Back to Clio matter">&larr;</a>
      <h1>Your 50deeds order</h1>
      <% if (orders.length) { %><button type="button" class="refresh" id="refreshBtn">&#8635; Refresh</button><% } %>
    </div>
    <p class="sub">Clio matter <strong><%= matterRef || '—' %></strong></p>

    <% if (!orders.length) { %>
      <div class="card"><div class="empty">No 50deeds orders for this matter yet. Use <strong>Order deed transfer with 50deeds</strong> to create one.</div></div>
    <% } %>

    <% orders.forEach(function(o){ %>
      <div class="card" data-draft="<%= o.draftId %>">
        <div class="row1">
          <div class="ordno">Order <code><%= o.customOrderId || o.orderId %></code></div>
          <span class="badge<%= o.removed ? ' removed' : '' %>" id="badge-<%= o.draftId %>"><%= o.status %></span>
        </div>
        <% if (o.transfer) { %><div class="meta">Transfer: <%= o.transfer %></div><% } %>
        <% if (o.propertyAddress) { %><div class="meta">Property: <%= o.propertyAddress %></div><% } %>
        <% if (o.total) { %><div class="meta" id="total-<%= o.draftId %>">Total: <%= o.total %></div><% } %>

        <div class="docs-head">
          <div class="lab">Documents <span class="muted">(send signed deed / supporting files to 50deeds)</span></div>
          <label class="upload-btn">&uarr; Upload to 50deeds
            <input type="file" class="fileInput" data-draft="<%= o.draftId %>" multiple accept=".pdf,.png,.jpg,.jpeg,.tif,.tiff,.doc,.docx" style="display:none" />
          </label>
        </div>
        <div class="uploads" id="uploads-<%= o.draftId %>">
          <% (o.attachments || []).forEach(function(a){ %>
            <div class="frow">
              <% if (a.file_url) { %>
                <a href="<%= a.file_url %>" target="_blank" rel="noopener">📄 <%= a.file_name || a.name || 'document' %></a>
              <% } else { %>
                <span>📄 <%= a.file_name || a.name || 'document' %></span>
              <% } %>
              <% var meta = [a.file_size ? Math.max(1, Math.round(a.file_size / 1024)) + ' KB' : '', a.uploaded_et || ''].filter(Boolean).join(' · '); %>
              <% if (meta) { %><span class="muted"><%= meta %></span><% } %>
            </div>
          <% }) %>
        </div>
        <div class="sub-note" id="status-<%= o.draftId %>"></div>
      </div>
    <% }) %>
  </div>

  <script>
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    function attachHtml(a) {
      const name = esc(a.file_name || a.name || 'document');
      const bits = [];
      if (a.file_size) bits.push(Math.max(1, Math.round(a.file_size / 1024)) + ' KB');
      if (a.uploaded_et) bits.push(esc(a.uploaded_et));
      const meta = bits.length ? '<span class="muted">' + bits.join(' · ') + '</span>' : '';
      const label = a.file_url
        ? '<a href="' + esc(a.file_url) + '" target="_blank" rel="noopener">📄 ' + name + '</a>'
        : '<span>📄 ' + name + '</span>';
      return '<div class="frow">' + label + meta + '</div>';
    }

    // Upload (post-order) — reuses /order/:id/upload, which forwards to the order.
    document.querySelectorAll('.fileInput').forEach((inp) => {
      inp.addEventListener('change', async (e) => {
        const draft = inp.dataset.draft;
        const list = document.getElementById('uploads-' + draft);
        const status = document.getElementById('status-' + draft);
        for (const f of Array.from(e.target.files || [])) {
          if (f.size > 14 * 1024 * 1024) {
            status.textContent = f.name + ' is too large (max 14 MB).';
            continue;
          }
          if (!['pdf', 'png', 'jpg', 'jpeg', 'tif', 'tiff', 'doc', 'docx'].includes((f.name.split('.').pop() || '').toLowerCase())) {
            status.textContent = f.name + ': unsupported type. Allowed: PDF, PNG, JPG, TIFF, DOC, DOCX.';
            continue;
          }
          status.textContent = 'Uploading ' + f.name + '…';
          try {
            const b64 = await new Promise((res, rej) => {
              const fr = new FileReader();
              fr.onload = () => res(String(fr.result).split(',')[1]);
              fr.onerror = rej;
              fr.readAsDataURL(f);
            });
            const r = await fetch('/order/' + draft + '/upload', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ file_name: f.name, mime: f.type, data_base64: b64 }),
            });
            const d = await r.json();
            if (r.ok) {
              list.insertAdjacentHTML('beforeend', attachHtml({ file_url: d.file_url, file_name: d.file_name, file_size: d.file_size, uploaded_et: d.uploaded_et }));
              status.textContent = d.attached
                ? ''
                : 'Uploaded, but couldn’t attach to 50deeds — please try again.';
            } else {
              status.textContent = d.error || 'Upload failed.';
            }
          } catch (err) {
            status.textContent = 'Upload failed for ' + f.name + '.';
          }
        }
        e.target.value = '';
      });
    });

    // Refresh — re-fetch live status + attachments per order (no Clio nonce needed).
    async function refreshOrder(draft) {
      try {
        const r = await fetch('/order/' + draft + '/status');
        if (!r.ok) return;
        const d = await r.json();
        const badge = document.getElementById('badge-' + draft);
        if (badge && d.status) { badge.textContent = d.status; badge.classList.toggle('removed', !!d.removed); }
        const total = document.getElementById('total-' + draft);
        if (total && d.total) total.textContent = 'Total: ' + d.total;
        const list = document.getElementById('uploads-' + draft);
        if (list) list.innerHTML = (d.attachments || []).map(attachHtml).join('');
      } catch (e) {}
    }
    const refreshBtn = document.getElementById('refreshBtn');
    if (refreshBtn) {
      refreshBtn.addEventListener('click', async () => {
        refreshBtn.disabled = true;
        const label = refreshBtn.innerHTML;
        refreshBtn.textContent = 'Refreshing…';
        await Promise.all(Array.from(document.querySelectorAll('[data-draft]')).map((c) => refreshOrder(c.dataset.draft)));
        refreshBtn.innerHTML = label;
        refreshBtn.disabled = false;
      });
    }
  </script>
</body>
</html>
