<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>New Order — 50deeds</title>
  <style>
    :root{--ink:#1a2b4a;--muted:#6b7a93;--line:#e2e8f2;--chip:#eaf0fb;--chipink:#2b4a86;--blue:#2563eb;--blue-dim:#a9bff2;--soft:#f7f9fc;--green:#1a7f4b;--amber:#b26a00;}
    *{box-sizing:border-box;}
    body{font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:var(--ink);background:#fafbfd;margin:0;}
    .wrap{max-width:760px;margin:0 auto;padding:24px 20px 80px;}
    .top{display:flex;align-items:center;gap:12px;margin:8px 0 22px;}
    .back{display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border:1px solid var(--line);border-radius:10px;background:#fff;color:var(--ink);text-decoration:none;font-size:18px;}
    h1{font-size:24px;margin:0;font-weight:800;}
    .card{background:#fff;border:1px solid var(--line);border-radius:14px;padding:24px;}
    .card-title{font-size:16px;font-weight:800;margin:0 0 18px;}
    label{display:block;font-size:14px;font-weight:700;margin:18px 0 8px;}
    label:first-of-type{margin-top:0;}
    input[type=text],input[type=email],textarea,select{width:100%;padding:12px 14px;border:1px solid var(--line);border-radius:10px;font-size:14px;font-family:inherit;background:#fff;color:var(--ink);}
    input::placeholder,textarea::placeholder{color:#9aa7bd;}
    textarea{min-height:84px;resize:vertical;}
    .transfer{background:var(--soft);border:1px solid var(--line);border-radius:10px;padding:14px 16px;}
    .transfer .line{display:flex;align-items:center;gap:8px;flex-wrap:wrap;font-size:14px;color:var(--muted);}
    .chip{display:inline-block;background:var(--chip);color:var(--chipink);font-weight:700;font-size:13px;padding:3px 12px;border-radius:999px;}
    .arrow{color:var(--muted);font-weight:700;}
    .transfer .desc{color:var(--muted);font-style:italic;font-size:13px;margin-top:8px;}
    .transfer select{margin-top:12px;font-size:13px;padding:9px 10px;}
    .pricebox{background:var(--soft);border:1px solid var(--line);border-radius:10px;padding:16px;display:flex;align-items:center;gap:12px;color:var(--muted);font-size:14px;margin-top:18px;}
    .pricebox.has-price{color:var(--ink);}
    .pricebox .amt{font-size:22px;font-weight:800;}
    .ico{width:22px;height:22px;border-radius:50%;border:1.5px solid var(--muted);display:inline-flex;align-items:center;justify-content:center;font-size:12px;font-style:italic;flex:0 0 auto;}
    .docs-head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:22px;}
    .docs-head .lab{font-size:13px;font-weight:700;}
    .docs-head .lab .muted{font-weight:500;}
    .upload-btn{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line);background:#fff;border-radius:10px;padding:9px 14px;font-weight:700;font-size:13px;cursor:pointer;white-space:nowrap;}
    .uploads{margin-top:12px;display:flex;flex-direction:column;gap:8px;}
    .uploads .row{display:flex;justify-content:space-between;align-items:center;font-size:13px;background:var(--soft);border:1px solid var(--line);border-radius:8px;padding:9px 12px;}
    .muted{color:var(--muted);}
    .sub-note{font-size:12px;color:var(--muted);margin-top:8px;}
    .submit-row{display:flex;justify-content:flex-end;margin-top:22px;}
    .btn-submit{background:var(--blue);color:#fff;border:none;border-radius:12px;padding:13px 24px;font-weight:800;font-size:15px;cursor:pointer;}
    .btn-submit:disabled{background:var(--blue-dim);cursor:not-allowed;}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <a class="back" href="#" onclick="history.back();return false;" aria-label="Back">&larr;</a>
      <h1>New Order</h1>
    </div>

    <form id="orderForm" method="POST" action="/order/<%= draftId %>/submit">
      <div class="card">
        <div class="card-title">Order Details</div>

        <label>Type of Transfers</label>
        <div class="transfer">
          <div class="line">
            <span>From:</span> <span class="chip" id="fromChip">&mdash;</span>
            <span class="arrow">&rarr;</span>
            <span>To:</span> <span class="chip" id="toChip">&mdash;</span>
          </div>
          <div class="desc" id="transferDesc"></div>
          <select name="deedType" id="deedType" required>
            <% deedTypes.forEach(function(t){ %>
              <option value="<%= t.value %>" <%= selectedDeedType === t.value ? 'selected' : '' %>>
                <%= t.transfer %><%= (/reportable/i.test(t.value) && !/non-reportable/i.test(t.value)) ? ' — FinCEN reportable' : '' %>
              </option>
            <% }) %>
          </select>
        </div>

        <label>Property Address</label>
        <input type="text" name="propertyAddress" id="propertyAddress" value="<%= d.propertyAddress.value %>" placeholder="Enter the property address..." autocomplete="off" required />

        <label>Homeowner Name</label>
        <input type="text" name="grantorName" id="grantorName" value="<%= d.grantorName.value %>" placeholder="As shown on last recorded deed" required />

        <label>New Owner Name <span class="muted" id="toLabel"></span></label>
        <input type="text" name="granteeName" id="granteeName" value="<%= d.granteeName.value %>" placeholder="Name of the trust, individual, or company receiving title" required />

        <div class="pricebox" id="priceBox">
          <span class="ico">i</span>
          <span id="priceText">Enter valid property address to calculate the price.</span>
        </div>

        <label>Additional Instructions (Optional)</label>
        <textarea name="additionalInstructions" placeholder="Enter any special requests or notes here..."><%= d.additionalInstructions ? d.additionalInstructions.value : '' %></textarea>

        <div class="docs-head">
          <div class="lab">Supporting Documents <span class="muted">(Upload Homeowner ID, last recorded deed and/or Certificate of Trust)</span></div>
          <label class="upload-btn">&uarr; Upload Files
            <input type="file" id="fileInput" multiple style="display:none" />
          </label>
        </div>
        <div class="uploads" id="uploads"></div>
        <div class="sub-note" id="uploadStatus"></div>
      </div>

      <!-- Required by the Enterprise order but derived/pre-filled, not shown as primary fields -->
      <input type="hidden" name="contactEmail" id="contactEmail" value="<%= d.contactEmail.value %>" />
      <input type="hidden" name="county" id="county" value="<%= d.county.value %>" />
      <input type="hidden" name="state" id="state" value="<%= d.state.value %>" />
      <input type="hidden" name="apn" id="apn" value="<%= d.apn.value %>" />
      <input type="hidden" name="legalDescription" id="legalDescription" value="<%= d.legalDescription.value %>" />
      <input type="hidden" name="priorDeedReference" id="priorDeedReference" value="<%= d.priorDeedReference.value %>" />
      <input type="hidden" name="matterReference" value="<%= d.matterReference.value %>" />

      <div class="submit-row">
        <button type="submit" class="btn-submit" id="submitBtn" disabled>Submit Order &#9658;</button>
      </div>
      <p class="sub-note" style="text-align:right">Secure payment via Stripe · recorded against Clio matter <%= d.matterReference.value || '' %>.</p>
    </form>
  </div>

  <script>
    const $ = (id) => document.getElementById(id);
    const DEED = <%- JSON.stringify(deedMeta) %>;

    function refreshTransfer() {
      const m = DEED[$('deedType').value] || { from: '—', to: '—', transfer: '' };
      $('fromChip').textContent = m.from;
      $('toChip').textContent = m.to;
      $('transferDesc').textContent = m.transfer;
      $('toLabel').textContent = m.to ? '(the ' + m.to + ')' : '';
    }

    function setPrice(html, isPrice) {
      $('priceText').innerHTML = html;
      $('priceBox').classList.toggle('has-price', !!isPrice);
    }

    function validate() {
      const ok = $('deedType').value && $('propertyAddress').value.trim()
        && $('grantorName').value.trim() && $('granteeName').value.trim();
      $('submitBtn').disabled = !ok;
    }

    async function lookupAndPrice() {
      const address = $('propertyAddress').value.trim();
      if (!address) { setPrice('Enter valid property address to calculate the price.', false); return; }
      setPrice('Calculating price…', false);
      try {
        const r = await fetch('/order/<%= draftId %>/county-lookup', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ address, state: $('state').value, county: $('county').value }),
        });
        const d = await r.json();
        if (d.found) {
          $('apn').value = d.apn || '';
          $('legalDescription').value = d.legalDescription || '';
          $('priorDeedReference').value = d.priorDeedReference || '';
          if (d.county) $('county').value = d.county;
          if (d.state) $('state').value = d.state;
        }
      } catch (e) {}
      await updatePrice();
    }

    async function updatePrice() {
      const state = $('state').value.trim().toUpperCase();
      if (state.length !== 2) { setPrice('Enter valid property address to calculate the price.', false); return; }
      try {
        const p = new URLSearchParams({ state, county: $('county').value.trim(), deedType: $('deedType').value });
        const r = await fetch('/order/price?' + p.toString());
        const d = await r.json();
        setPrice('<span class="amt">' + (d.display || '—') + '</span>', true);
      } catch (e) {
        setPrice('Could not calculate price automatically — we’ll confirm before payment.', false);
      }
    }

    // File upload: read as base64, POST JSON, list the result.
    $('fileInput').addEventListener('change', async (e) => {
      const files = Array.from(e.target.files || []);
      for (const f of files) {
        $('uploadStatus').textContent = 'Uploading ' + f.name + '…';
        try {
          const b64 = await new Promise((res, rej) => {
            const fr = new FileReader();
            fr.onload = () => res(String(fr.result).split(',')[1]);
            fr.onerror = rej;
            fr.readAsDataURL(f);
          });
          const r = await fetch('/order/<%= draftId %>/upload', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ file_name: f.name, mime: f.type, data_base64: b64 }),
          });
          const d = await r.json();
          if (r.ok) {
            const row = document.createElement('div');
            row.className = 'row';
            row.innerHTML = '<span>📄 ' + d.file_name + '</span><span class="muted">'
              + Math.max(1, Math.round(d.file_size / 1024)) + ' KB</span>';
            $('uploads').appendChild(row);
            $('uploadStatus').textContent = '';
          } else {
            $('uploadStatus').textContent = d.error || 'Upload failed.';
          }
        } catch (err) {
          $('uploadStatus').textContent = 'Upload failed for ' + f.name + '.';
        }
      }
      e.target.value = '';
    });

    $('deedType').addEventListener('change', () => { refreshTransfer(); updatePrice(); validate(); });
    ['propertyAddress', 'grantorName', 'granteeName'].forEach((id) => $(id).addEventListener('input', validate));
    $('propertyAddress').addEventListener('blur', lookupAndPrice);

    refreshTransfer();
    validate();
    if ($('propertyAddress').value.trim()) lookupAndPrice();
  </script>
</body>
</html>
