<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Order a deed — 50deeds</title>
  <style>
    :root { --navy:#1a2b4a; --blue:#2563eb; --line:#dbe2ee; --bg:#f6f8fc; --green:#1a7f4b; --amber:#b26a00; }
    * { box-sizing: border-box; }
    body { font-family: system-ui, -apple-system, Segoe UI, sans-serif; color: var(--navy); background: var(--bg); margin: 0; }
    .wrap { max-width: 720px; margin: 0 auto; padding: 32px 20px 80px; }
    h1 { font-size: 22px; margin: 0 0 4px; }
    .sub { color:#5b6b86; margin: 0 0 24px; font-size: 14px; }
    .card { background:#fff; border:1px solid var(--line); border-radius:12px; padding:20px; margin-bottom:18px; }
    .card h2 { font-size:15px; margin:0 0 14px; text-transform:uppercase; letter-spacing:.04em; color:#5b6b86; }
    label { display:block; font-size:13px; font-weight:600; margin:12px 0 4px; }
    input, select, textarea { width:100%; padding:10px 12px; border:1px solid var(--line); border-radius:8px; font-size:14px; font-family:inherit; }
    textarea { min-height:70px; resize:vertical; }
    .tag { display:inline-block; font-size:11px; font-weight:700; padding:2px 8px; border-radius:999px; margin-left:8px; vertical-align:middle; }
    .tag.clio { background:#e7f0ff; color:var(--blue); }
    .tag.confirm { background:#fff3e0; color:var(--amber); }
    .tag.auto { background:#e7f7ee; color:var(--green); }
    .row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
    .hint { font-size:12px; color:#7a8aa6; margin-top:4px; }
    button { font:inherit; cursor:pointer; border:none; border-radius:8px; padding:12px 18px; font-weight:700; }
    .btn-primary { background:var(--blue); color:#fff; width:100%; font-size:16px; }
    .btn-secondary { background:#eef2f9; color:var(--navy); }
    .price { font-size:20px; font-weight:800; }
    .redacted { color:var(--amber); font-size:12px; }
    .lookup-status { font-size:13px; margin-top:8px; min-height:18px; }
    .footer-note { font-size:12px; color:#7a8aa6; text-align:center; margin-top:14px; }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>Order a deed with 50deeds</h1>
    <p class="sub">
      Pre-filled from Clio matter <strong><%= d.matterReference.value || '—' %></strong>.
      Fields marked <span class="tag clio">from Clio</span> came from the matter;
      <span class="tag confirm">confirm</span> need your input;
      <span class="tag auto">auto-filled</span> populate from the county record once you confirm the property address.
    </p>

    <form id="orderForm" method="POST" action="/order/<%= draftId %>/submit">
      <div class="card">
        <h2>Parties</h2>

        <label>Grantor name(s)
          <%- d.grantorName.source === 'clio' ? '<span class="tag clio">from Clio</span>' : '<span class="tag confirm">confirm</span>' %>
        </label>
        <input name="grantorName" value="<%= d.grantorName.value %>" required />

        <label>Grantor mailing address
          <%- d.grantorAddress.source === 'clio' ? '<span class="tag clio">from Clio</span>' : '<span class="tag confirm">confirm</span>' %>
        </label>
        <textarea name="grantorAddress" required><%= d.grantorAddress.value %></textarea>

        <label>Grantee name(s) <span class="tag confirm">confirm</span></label>
        <% if (d.granteeCandidates && d.granteeCandidates.length) { %>
          <select id="granteePicker">
            <option value="">— pick from matter contacts or type below —</option>
            <% d.granteeCandidates.forEach(function(g){ %>
              <option value="<%= g.name %>" <%= g.redacted ? 'disabled' : '' %>>
                <%= g.name || '(unnamed)' %><%= g.relationship ? ' — ' + g.relationship : '' %><%= g.redacted ? ' (no permission)' : '' %>
              </option>
            <% }) %>
          </select>
          <% if (d.granteeCandidates.some(function(g){return g.redacted})) { %>
            <div class="redacted">Some related contacts are hidden because you lack permission in Clio. Type the grantee manually if needed.</div>
          <% } %>
        <% } %>
        <input name="granteeName" id="granteeName" value="<%= d.granteeName.value %>" placeholder="Grantee name(s)" style="margin-top:8px" required />
      </div>

      <div class="card">
        <h2>Property</h2>

        <label>Property street address
          <%- d.propertyAddress.source && d.propertyAddress.source.indexOf('clio') === 0 ? '<span class="tag clio">from Clio</span>' : '<span class="tag confirm">confirm</span>' %>
        </label>
        <input name="propertyAddress" id="propertyAddress" value="<%= d.propertyAddress.value %>" placeholder="123 Main St, City" required />
        <div class="row">
          <div>
            <label>County <span class="tag confirm">confirm</span></label>
            <input name="county" id="county" value="<%= d.county.value %>" />
          </div>
          <div>
            <label>State <%- d.state.source === 'derived' ? '<span class="tag clio">derived</span>' : '<span class="tag confirm">confirm</span>' %></label>
            <input name="state" id="state" value="<%= d.state.value %>" maxlength="2" required />
          </div>
        </div>

        <button type="button" class="btn-secondary" id="lookupBtn" style="margin-top:12px">
          Confirm address → look up county record
        </button>
        <div class="lookup-status" id="lookupStatus"></div>

        <label>APN / Parcel number <span class="tag auto">auto-filled</span></label>
        <input name="apn" id="apn" value="<%= d.apn.value %>" placeholder="Populated from county record" />

        <label>Legal description <span class="tag auto">auto-filled</span></label>
        <textarea name="legalDescription" id="legalDescription" placeholder="Populated from county record"><%= d.legalDescription.value %></textarea>

        <label>Prior deed / vesting reference <span class="tag auto">auto-filled</span></label>
        <input name="priorDeedReference" id="priorDeedReference" value="<%= d.priorDeedReference.value %>" placeholder="Populated from county record" />
      </div>

      <div class="card">
        <h2>Deed</h2>
        <label>Deed type <span class="tag confirm">confirm</span></label>
        <select name="deedType" id="deedType" required>
          <option value="">— select —</option>
          <option value="warranty">Warranty deed</option>
          <option value="quitclaim">Quitclaim deed</option>
          <option value="tod">Transfer-on-death (TOD) deed</option>
          <option value="grant">Grant deed</option>
        </select>

        <label>Matter reference <span class="tag clio">from Clio</span></label>
        <input name="matterReference" value="<%= d.matterReference.value %>" readonly />
      </div>

      <div class="card" style="display:flex;align-items:center;justify-content:space-between">
        <div>Deed order total</div>
        <div class="price" id="priceDisplay"><%= priceDisplay %></div>
      </div>

      <button type="submit" class="btn-primary">Continue to secure payment →</button>
      <p class="footer-note">You'll complete payment via Stripe. Your order is recorded against Clio matter <%= d.matterReference.value || '' %>.</p>
    </form>
  </div>

  <script>
    const $ = (id) => document.getElementById(id);

    // Grantee picker -> name field
    if ($('granteePicker')) {
      $('granteePicker').addEventListener('change', (e) => {
        if (e.target.value) $('granteeName').value = e.target.value;
      });
    }

    // County record lookup (the differentiator)
    $('lookupBtn').addEventListener('click', async () => {
      const address = $('propertyAddress').value.trim();
      if (!address) { $('lookupStatus').textContent = 'Enter a property address first.'; return; }
      $('lookupStatus').textContent = 'Looking up county record…';
      $('lookupBtn').disabled = true;
      try {
        const res = await fetch('/order/<%= draftId %>/county-lookup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ address, state: $('state').value, county: $('county').value }),
        });
        const data = await res.json();
        if (!res.ok || !data.found) {
          $('lookupStatus').innerHTML = '<span style="color:#b26a00">No county record found automatically — enter APN / legal description manually.</span>';
        } else {
          $('apn').value = data.apn || '';
          $('legalDescription').value = data.legalDescription || '';
          $('priorDeedReference').value = data.priorDeedReference || '';
          if (data.county) $('county').value = data.county;
          if (data.state) $('state').value = data.state;
          $('lookupStatus').innerHTML = '<span style="color:#1a7f4b">✓ County record found — APN, legal description, and prior deed populated. Please verify.</span>';
        }
      } catch (e) {
        $('lookupStatus').innerHTML = '<span style="color:#b00">Lookup failed — enter details manually.</span>';
      } finally {
        $('lookupBtn').disabled = false;
        updatePrice();
      }
    });

    // Live price by state
    async function updatePrice() {
      const state = $('state').value.trim().toUpperCase();
      if (state.length !== 2) return;
      try {
        const res = await fetch('/order/price?state=' + encodeURIComponent(state));
        const data = await res.json();
        if (data.display) $('priceDisplay').textContent = data.display;
      } catch {}
    }
    $('state').addEventListener('change', updatePrice);
  </script>
</body>
</html>
